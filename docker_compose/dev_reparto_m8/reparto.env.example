# Copy to api.env and replace every "changethis" with real values.
# Does NOT include auth-service-only secrets (FIRST_SUPERUSER, PRIVATE_API_SECRET,
# TOKENS_ENCRYPTION_KEY, ACCESS_PRIVATE_KEY_FILE).

# ── Identity ──────────────────────────────────────────────────────────────────
DOMAIN=localhost
ENVIRONMENT=local
PROJECT_NAME=M8FastApi
STACK_NAME=m8-fastapi-service

# ── API & docs ────────────────────────────────────────────────────────────────
API_PREFIX=/reparto
SET_OPEN_API=true
SET_DOCS=true
SET_REDOC=true

# ── CORS / Frontend ───────────────────────────────────────────────────────────
BACKEND_HOST=http://127.0.0.1:9000
FRONTEND_HOST=http://localhost:5173
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:9000,https://localhost,https://localhost:9000,https://localhost:5173

# ── Service role & auth routing ───────────────────────────────────────────────
AUTH_SERVICE_ROLE=consumer
AUTH_PREFIX=/user

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
SELECTED_DB=Postgres
DB_HOST=m8_db
DB_PORT=5432
DB_DATABASE=reparto_db
DB_USER=changethis_reparto_user
DB_PASSWORD=changethis

# ── Table prefix (every reparto table becomes "<prefix>_<name>") ────────────
TABLES_PREFIX=reparto

# ── Token verification — HS256 (shared key; no auth-service secrets here) ─────
ACCESS_SECRET_KEY=changethis
REFRESH_SECRET_KEY=changethis
ACCESS_TOKEN_ALGORITHM=HS256
REFRESH_TOKEN_ALGORITHM=HS256
TOKEN_MODE=stateful
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=3600

# ── Token boundary claims — REQUIRED under secure-by-default ──────────────────
# auth-sdk-m8 >= 1.0.0 turns TOKEN_STRICT_VALIDATION on by default: this consumer
# fails closed at boot unless both are set, and rejects tokens whose iss/aud claim
# differs. Must match auth_user_service TOKEN_ISSUER / TOKEN_AUDIENCE exactly.
# Opt out (legacy/local only) with TOKEN_STRICT_VALIDATION=false.
TOKEN_ISSUER=https://auth.example.com
TOKEN_AUDIENCE=https://api.example.com

# ── Token revocation (stateful mode) ──────────────────────────────────────────
# Per-consumer private-API bootstrap credential (v1.0.0). Present
# X-Internal-Client=INTERNAL_CLIENT_ID + X-Internal-Token=PRIVATE_API_SECRET,
# matching an entry in the auth service PRIVATE_API_CONSUMERS map (the legacy
# bare shared-secret gate is retired). Auth Redis stays private to
# auth_user_service — consumer calls this HTTP endpoint instead.
INTROSPECTION_URL=http://auth_user_service:8000/user/private/v1/jti-status
INTERNAL_CLIENT_ID=reparto-api
PRIVATE_API_SECRET=changethis

# ── Auth degradation policy (failure-mode matrix) ────────────────────────────
# Default posture: fail_closed for revocation, session writes, and refresh
# validation; fail_open for rate limiting. All overridable per-control.
#
# Availability-first: accept requests when revocation check is unavailable
#ACCESS_REVOCATION_FAILURE_MODE=fail_open
#
# High-security: force all controls closed regardless of per-control settings
#AUTH_STRICT_MODE=true
#
# Per-control overrides (uncomment as needed)
#REFRESH_VALIDATION_FAILURE_MODE=fail_closed
#SESSION_WRITE_FAILURE_MODE=fail_closed
#RATE_LIMIT_FAILURE_MODE=fail_open


# ── Event signing — auth-sdk-m8 1.0.0 boot validator (fail-closed when enabled) ──
# DEV ONLY — replace with a secrets-managed value; boot fails closed without it
# Must match EVENT_SIGNING_KEY in auth.env.example for this stack.
EVENT_SIGNING_ENABLED=true
EVENT_SIGNING_KEY=changethis

# ── Auth event stream (best-effort cache eviction) ────────────────────────────
# Streams session-revoked / user-deleted events from fa-auth to evict the
# REVOCATION_CACHE_TTL_SECONDS positive-validation cache early.
# Stream URL is derived from INTROSPECTION_URL — no extra URL needed.
# Set REVOCATION_CACHE_TTL_SECONDS > 0 to enable the local cache (default 0 = off).
REVOCATION_CACHE_TTL_SECONDS=30
# EVENT_STREAM_CONNECT_TIMEOUT=5.0
# EVENT_STREAM_READ_TIMEOUT=60.0

# ── Observability ─────────────────────────────────────────────────────────────
METRICS_ENABLED=false
METRICS_GROUPS=all

# ── Response security headers (auth-sdk-m8 >= 1.2.1, three tiers) ────────────────
# Applied by fastapi-m8 create_app. Tier 1 (X-Content-Type-Options, X-Frame-Options)
# is always on; tier 2 (Referrer-Policy, Permissions-Policy) applies on the production
# gate. Tier 3 below is browser-persisted and hard to reverse (HSTS poisons a host's
# HTTPS cache for its full max-age), so it is express opt-in, defaults to off, and is
# NEVER emitted on a local stack even if enabled. Enable only on a TLS-terminated host.
#HSTS_ENABLED=false
#CONTENT_SECURITY_POLICY_ENABLED=false
#HSTS_MAX_AGE=31536000
#HSTS_INCLUDE_SUBDOMAINS=true
#CONTENT_SECURITY_POLICY=
