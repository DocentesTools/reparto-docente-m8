# Copy to auth.env — auth_user_service complete configuration.
# Generate secret keys (32+ chars, upper, lower, digit, non-alphanumeric):
#   python -c "import secrets; print(secrets.token_urlsafe(48))"

DOMAIN=localhost
ENVIRONMENT=local
PROJECT_NAME=MyAuthService
STACK_NAME=my-auth-service

API_PREFIX=/user
SET_OPEN_API=true
SET_DOCS=true
SET_REDOC=true
# Explicitly enable docs in ENVIRONMENT=production (auth-sdk-m8 ≥ 0.7.3). Default: off.
# Only for public/open-source APIs. Emits a startup warning when enabled.
#SERVE_DOCS_IN_PRODUCTION=false

BACKEND_HOST=http://127.0.0.1:9000
FRONTEND_HOST=http://localhost:5173
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:9000

AUTH_SERVICE_ROLE=issuer

SELECTED_DB=Postgres
DB_HOST=m8_db
DB_PORT=5432
DB_DATABASE=auth_db
DB_USER=changethis_auth_user
DB_PASSWORD=changethis

REDIS_HOST=redis_cache
REDIS_PORT=6379
REDIS_USER=auth
REDIS_PASSWORD=changethis
#REDIS_SSL=false
#REDIS_SSL_CA=   # path to CA cert — required when REDIS_SSL=true
#REDIS_SSL_CERT= # path to client cert for mTLS — must pair with REDIS_SSL_KEY
#REDIS_SSL_KEY=  # path to client key for mTLS — must pair with REDIS_SSL_CERT

ACCESS_TOKEN_ALGORITHM=HS256
REFRESH_TOKEN_ALGORITHM=HS256
ACCESS_SECRET_KEY=changethis
REFRESH_SECRET_KEY=changethis
#REFRESH_SECRET_KEY_OLD=
TOKEN_MODE=stateful
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=3600

# ── Token boundary claims — REQUIRED under secure-by-default ──────────────────
# auth-sdk-m8 >= 1.0.0 turns TOKEN_STRICT_VALIDATION on by default: the service
# fails closed at boot unless both are set, and every validator requires an exact
# iss/aud match. Use identical values in this auth service and every consumer.
# Opt out (legacy/local only) with TOKEN_STRICT_VALIDATION=false.
TOKEN_ISSUER=https://auth.example.com
TOKEN_AUDIENCE=https://api.example.com

FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis
PRIVATE_API_SECRET=changethis
# Per-consumer private-API credentials (v1.0.0 — REQUIRED once a consumer
# calls /private/*; the legacy single-PRIVATE_API_SECRET gate is retired).
# JSON map of consumer id -> {secret, scopes}. The example `api` consumer
# authenticates as `example-api` with the secret below, which MUST equal that
# consumer's api.env PRIVATE_API_SECRET. Prefer a hashed `sha256$<salt>$<digest>`
# secret in production. Empty -> every /private/* call fails closed (401).
PRIVATE_API_CONSUMERS={"reparto-api":{"secret":"changethis","scopes":["introspection","event-stream"]}}
SESSION_SECRET=changethis
TOKENS_ENCRYPTION_KEY=changethis
# Set only during a TOKENS_ENCRYPTION_KEY rotation: the previous key, kept so
# external OAuth tokens encrypted under it stay decryptable (MultiFernet new→old).
# Remove once every stored token has been re-encrypted under / expired past the
# new key. Leave commented in steady state.
#TOKENS_ENCRYPTION_KEY_OLD=

# ── Event signing — auth-sdk-m8 1.0.0 boot validator (fail-closed when enabled) ──
# DEV ONLY — replace with a secrets-managed value; boot fails closed without it
EVENT_SIGNING_ENABLED=true
EVENT_SIGNING_KEY=changethis

# Auth event stream — SSE bridge on the private API (GET /private/v1/events/stream).
# Best-effort cache-eviction accelerator; the JTI blacklist stays authoritative.
# Payloads are HMAC-signed with EVENT_SIGNING_KEY above.
EVENT_STREAM_ENABLED=true
EVENT_STREAM_BUFFER_SIZE=256
EVENT_STREAM_HEARTBEAT_SECONDS=15
EVENT_STREAM_MAX_QUEUE=64

# ── Auth degradation policy (optional) ────────────────────────────────────────
# Controls behaviour when Redis is unavailable. Defaults shown.
# fail_open: allow through.  fail_closed: return 503.
# AUTH_STRICT_MODE=true overrides all per-control modes to fail_closed.
#AUTH_STRICT_MODE=false
#REFRESH_VALIDATION_FAILURE_MODE=fail_closed
#SESSION_WRITE_FAILURE_MODE=fail_closed
#RATE_LIMIT_FAILURE_MODE=fail_open
#ACCESS_REVOCATION_FAILURE_MODE=fail_open

# ── Proxy trust (optional) ───────────────────────────────────────────────────
# Number of trusted reverse-proxy hops in front of this service.
# Used to extract the real client IP from X-Forwarded-For.
# Set to 1 for a single Traefik instance; 0 for no proxy (direct access).
#TRUSTED_PROXY_COUNT=1

# ── Rate limiting (optional) ──────────────────────────────────────────────────
# Defaults shown. Warn at startup if effective rate exceeds 5 req/min (login)
# or 20 req/min (refresh). Refresh vars unused in stateless mode.
#LOGIN_RATE_LIMIT_REQUESTS=5
#LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
# Unused in stateless mode (no refresh tokens issued).
#REFRESH_RATE_LIMIT_REQUESTS=10
#REFRESH_RATE_LIMIT_WINDOW_MINUTES=5

METRICS_ENABLED=false
METRICS_GROUPS=all
# Dedicated credential for the deep /health detail gate (9.3). When set, callers
# presenting this value via X-Internal-Token receive the full infrastructure body;
# when unset the gate fails closed (no detail regardless of token). Must differ
# from PRIVATE_API_SECRET (startup rejects reuse). HEALTH_DETAIL_CREDENTIAL_FILE
# is also accepted for Docker/K8s file-mounted secrets.
#HEALTH_DETAIL_CREDENTIAL=changethis

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Chrome extension / native-app OAuth (optional) ────────────────────────────
# Fixed backend callback URI — must match Google Console exactly.
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/google-auth/oauth-callback/

# URI schemes accepted as redirect_target at /google-api/login-url/ (default shown).
# OAUTH_ALLOWED_REDIRECT_SCHEMES=chrome-extension://

# Optional: lock to specific extension IDs (empty = open public-client model).
# OAUTH_ALLOWED_REDIRECT_PREFIXES=chrome-extension://abc123def456.../

# Scheme-level CORS — required for Chrome extension fetch() calls.
# CORS_ALLOWED_ORIGIN_SCHEMES=chrome-extension://

# ── Response security headers (auth-sdk-m8 >= 1.2.1, three tiers) ────────────────
# Tier 1 (X-Content-Type-Options, X-Frame-Options) is always on; tier 2
# (Referrer-Policy, Permissions-Policy) applies on the production gate. Tier 3 below
# is browser-persisted and hard to reverse (HSTS poisons a host's HTTPS cache for
# its full max-age), so it is express opt-in, defaults to off, and is NEVER emitted
# on a local stack even if enabled. Enable only on a TLS-terminated public host.
#HSTS_ENABLED=false
#CONTENT_SECURITY_POLICY_ENABLED=false
#HSTS_MAX_AGE=31536000
#HSTS_INCLUDE_SUBDOMAINS=true
#CONTENT_SECURITY_POLICY=
